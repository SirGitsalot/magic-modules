load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//build_defs:product.bzl", "mm_template_library")

package(default_visibility = ["//mmv1:__subpackages__"])

mm_template_library(
    name = "acctest_templates",
    srcs = [
        "bootstrap_iam_test_utils.go",
        "diff_utils.go",
        "provider_test_utils.go",
        "resource_inventory_reader.go",
        "resource_test_utils.go",
        "tgc_utils.go",
        "vcr_utils.go",
    ],
    template_srcs = [
        "bootstrap_test_utils.go.tmpl",
        "test_utils.go.tmpl",
    ],
    version = "ga",
)

go_library(
    name = "acctest",
    srcs = [":acctest_templates"],
    importpath = "github.com/GoogleCloudPlatform/magic-modules/mmv1/third_party/terraform/acctest",
    deps = [
        "//mmv1/third_party/terraform/envvar",
        "@com_github_dnaeon_go_vcr//cassette",
        "@com_github_dnaeon_go_vcr//recorder",
        "@com_github_hashicorp_terraform_json//:terraform-json",
        "@com_github_hashicorp_terraform_plugin_framework//datasource",
        "@com_github_hashicorp_terraform_plugin_framework//diag",
        "@com_github_hashicorp_terraform_plugin_framework//provider",
        "@com_github_hashicorp_terraform_plugin_framework//resource",
        "@com_github_hashicorp_terraform_plugin_go//tfprotov5",
        "@com_github_hashicorp_terraform_plugin_log//tflog",
        "@com_github_hashicorp_terraform_plugin_sdk_v2//diag",
        "@com_github_hashicorp_terraform_plugin_sdk_v2//helper/schema",
        "@com_github_hashicorp_terraform_plugin_sdk_v2//terraform",
        "@com_github_hashicorp_terraform_plugin_testing//helper/resource",
        "@com_github_hashicorp_terraform_plugin_testing//plancheck",
        "@com_github_hashicorp_terraform_plugin_testing//terraform",
        "@in_gopkg_yaml_v2//:yaml_v2",
        "@org_golang_google_api//cloudresourcemanager/v1:cloudresourcemanager",
    ],
)

go_test(
    name = "acctest_test",
    srcs = [
        "diff_utils_test.go",
        "resource_inventory_test.go",
        "tgc_utils_test.go",
        "vcr_utils_test.go",
    ],
    embed = [":acctest"],
    deps = [
        "@com_github_dnaeon_go_vcr//cassette",
        "@com_github_hashicorp_terraform_plugin_framework//attr",
        "@com_github_hashicorp_terraform_plugin_framework//resource",
        "@com_github_hashicorp_terraform_plugin_framework//resource/schema",
        "@com_github_hashicorp_terraform_plugin_framework//types",
        "@com_github_hashicorp_terraform_plugin_sdk_v2//helper/schema",
        "@com_github_hashicorp_terraform_plugin_testing//helper/resource",
        "@com_github_hashicorp_terraform_plugin_testing//terraform",
    ],
)
